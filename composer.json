{
  "name": "tegos/web-defect",
  "description": "",
  "license": "MIT",
  "type": "project",
  "require": {
    "php": "^8.2",
    "intervention/image": "^3.0",
    "laravel/framework": "^12.0",
    "laravel/tinker": "^2.0",
    "ext-gd": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "classmap": [
      "database/seeds",
      "database/factories"
    ],
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "php artisan key:generate"
    ]
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
